# SMTP Configuration for Coinsider
# Copy this file to smtpcreds.env and fill in your credentials
#
# Place smtpcreds.env in one of these locations (checked in order):
#   1. One level above project folder (most secure, outside doc root)
#   2. Project root folder
#   3. api/ folder (least secure, for development only)

# SMTP Server Settings
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USERNAME=noreply@yourdomain.com
SMTP_PASSWORD=your-password-here
SMTP_ENCRYPTION=tls
SMTP_HELO=yourdomain.com

# Email From Settings
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Coinsider

# App URL for email links
APP_URL=https://yourdomain.com
